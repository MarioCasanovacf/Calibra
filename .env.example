# Base de datos (libSQL / SQLite)
#
# Desarrollo local: deja estas variables vacías o sin definir.
# Por defecto la app usa un archivo local `local.db` en la raíz del proyecto.
#
# Producción (Turso u otro servidor libSQL): define ambas.
#   1. Crea una base gratis en https://turso.tech
#   2. Copia la URL (libsql://...) y un token de autenticación.

# DATABASE_URL=libsql://tu-base.turso.io
# DATABASE_AUTH_TOKEN=tu-token-de-turso
